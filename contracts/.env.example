# Private key of the deployer wallet (testnet only — never use a mainnet key here).
# Never commit the real .env file.
DEPLOYER_PRIVATE_KEY=

# Override only if GIWA's official RPC changes; defaults to https://sepolia-rpc.giwa.io
GIWA_SEPOLIA_RPC_URL=

# Set after deployment, or fetched dynamically by scripts.
BUILDER_PASSPORT_CONTRACT_ADDRESS=
